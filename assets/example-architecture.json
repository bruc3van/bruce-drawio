    {"id": "user-service", "label": "用户服务\nUser Service", "type": "service", "x": 200, "y": 280, "width": 160, "height": 70},
    {"id": "order-service", "label": "订单服务\nOrder Service", "type": "service", "x": 480, "y": 280, "width": 160, "height": 70},
    {"id": "payment-service", "label": "支付服务\nPayment Service", "type": "service", "x": 760, "y": 280, "width": 160, "height": 70},
    {"id": "user-db", "label": "MySQL\n用户数据库", "type": "database", "x": 200, "y": 420, "width": 140, "height": 80},
    {"id": "order-db", "label": "MySQL\n订单数据库", "type": "database", "x": 480, "y": 420, "width": 140, "height": 80},
    {"id": "payment-db", "label": "MySQL\n支付数据库", "type": "database", "x": 760, "y": 420, "width": 140, "height": 80},
    {"id": "redis", "label": "Redis\n缓存", "type": "cache", "x": 500, "y": 550, "width": 120, "height": 70}
